# ==============================================================
# PRODUCTION configuration template
# Copy to .env and fill in ALL values — no defaults are safe for production.
# ==============================================================

# ---- REQUIRED: LLM Provider (at least one) ----
ANTHROPIC_API_KEY=             # REQUIRED: Your Anthropic / GLM API key
# OPENAI_API_KEY=              # Alternative: OpenAI API key

# ---- REQUIRED: Authentication ----
JWT_SECRET_KEY=                # REQUIRED: Generate with: openssl rand -hex 32
# API_KEY=                     # Optional: Static API key (alternative to JWT)

# ---- REQUIRED: CORS ----
CORS_ORIGINS=                  # REQUIRED: Your production domain(s), comma-separated
                                # Example: https://shop.example.com,https://admin.shop.example.com

# ---- REQUIRED: Database ----
DATABASE_URL=postgresql://USER:STRONG_PASSWORD@DB_HOST:5432/open_chat_shop
POSTGRES_USER=                 # REQUIRED: Database username (not 'commerce')
POSTGRES_PASSWORD=             # REQUIRED: Strong database password
POSTGRES_DB=open_chat_shop

# ---- REQUIRED: Redis ----
REDIS_URL=redis://:STRONG_PASSWORD@REDIS_HOST:6379/0
REDIS_PASSWORD=                # REQUIRED: Strong Redis password

# ---- REQUIRED: Grafana ----
GRAFANA_PASSWORD=              # REQUIRED: Grafana admin password (not 'admin')

# ---- Optional: Anthropic-compatible endpoint ----
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GLM_MODEL=glm-5.1

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DEPLOY_ENV=production

# ---- WeChat (if applicable) ----
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_TOKEN=
# WECHAT_ENCODING_AES_KEY=
# WECHAT_MINIPROGRAM_APP_ID=
# WECHAT_MINIPROGRAM_APP_SECRET=
# WECHAT_MINIPROGRAM_TOKEN=

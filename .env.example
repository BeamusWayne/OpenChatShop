# LLM Provider
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# Anthropic-compatible endpoint (e.g. Zhipu GLM)
ANTHROPIC_BASE_URL=https://api.anthropic.com
GLM_MODEL=glm-5.1

# Auth
JWT_SECRET_KEY=change-me-in-production
# Static API Key (optional, for simple auth without JWT)
API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql://commerce:commerce@localhost:5432/open_chat_shop

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# WeChat Official Account
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=

# WeChat Mini Program
WECHAT_MINIPROGRAM_APP_ID=
WECHAT_MINIPROGRAM_APP_SECRET=
WECHAT_MINIPROGRAM_TOKEN=
